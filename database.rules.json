{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name', 'email', 'createdAt'])",

        "trips": {
          "$tripId": {
            ".validate": "newData.hasChildren(['userId', 'from', 'to', 'date', 'totalCost', 'status', 'legs', 'createdAt']) && newData.child('userId').val() === auth.uid"
          }
        },

        "journey_searches": {
          "$searchId": {
            ".validate": "newData.hasChildren(['startPoint', 'busStation', 'destination', 'createdAt'])"
          }
        },

        "journey_plans": {
          "$planId": {
            ".validate": "newData.hasChildren(['searchParams', 'legs', 'totalCost', 'totalDuration', 'createdAt'])"
          }
        },

        "activities": {
          "$activityId": {
            ".validate": "newData.hasChildren(['type', 'title', 'description', 'createdAt'])"
          }
        },

        "location_shares": {
          "$shareId": {
            ".validate": "newData.hasChildren(['shareId', 'ownerUid', 'ownerName', 'sharedWith', 'expiresAt', 'createdAt', 'isActive']) && newData.child('shareId').val() === $shareId && newData.child('ownerUid').val() === auth.uid"
          }
        }
      }
    },

    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null && ((!data.exists() && newData.val() === auth.uid) || (data.val() === auth.uid && !newData.exists()))",
        ".validate": "!newData.exists() || ($username.matches(/^[a-z0-9_]{3,20}$/) && newData.isString())"
      }
    },

    "location_shares": {
      "$shareId": {
        ".read": "auth != null && (data.child('ownerUid').val() === auth.uid || data.child('sharedWith').hasChild(auth.uid) || data.child('sharedWith/0').val() === 'public')",
        ".write": "auth != null && (!data.exists() ? newData.child('ownerUid').val() === auth.uid : data.child('ownerUid').val() === auth.uid)",
        ".validate": "newData.hasChildren(['shareId', 'ownerUid', 'ownerName', 'sharedWith', 'expiresAt', 'createdAt', 'isActive']) && newData.child('shareId').val() === $shareId && newData.child('ownerUid').val() === auth.uid"
      }
    },

    "live_locations": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('live_locations/' + $uid + '/isSharing').val() === true)",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['lat', 'lng', 'timestamp', 'isSharing'])"
      }
    },

    "tracking": {
      "$tripId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['lastUpdated'])"
      }
    },

    "trips": {
      "$tripId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "passengers": {
          "$passengerId": {
            ".validate": "newData.hasChildren(['name', 'boardingPoint', 'eta', 'status'])"
          }
        }
      }
    }
  }
}
